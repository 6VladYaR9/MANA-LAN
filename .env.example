# Copy this file to server/.env

PORT=3001
HOST=127.0.0.1
CLIENT_URL=https://manalan.ru,https://www.manalan.ru

# Admin credentials are required in production.
# Generate a salt and hash, then set a non-default login:
# node -e "const { randomBytes, pbkdf2Sync } = require('crypto'); const password = process.argv[1]; const salt = randomBytes(16).toString('hex'); const hash = pbkdf2Sync(password, salt, 120000, 32, 'sha256').toString('hex'); console.log(`ADMIN_PASSWORD_SALT=${salt}\nADMIN_PASSWORD_HASH=${hash}`);" "CHANGE_ME"
ADMIN_LOGIN=
ADMIN_PASSWORD_SALT=
ADMIN_PASSWORD_HASH=
ADMIN_LOGIN_MAX_ATTEMPTS=5
ADMIN_LOGIN_WINDOW_MS=60000

# Persistent runtime state is required in production.
DATA_DIR=/var/lib/manalan
STATE_FILE=
STATE_STORE_DISABLED=0

# Trust Caddy/Timeweb reverse-proxy headers only when Node listens on 127.0.0.1 behind that proxy.
TRUST_PROXY=1

# Short-lived access/session token windows.
ADMIN_SESSION_TTL_MS=43200000
ROOM_ACCESS_TTL_MS=43200000
PLAYER_SESSION_TTL_MS=43200000

# Password check rate limits.
ROOM_PASSWORD_MAX_ATTEMPTS=5
ROOM_PASSWORD_WINDOW_MS=60000

# Google Sheets / bracket
GOOGLE_SHEETS_ID=1BDsLdV_SgKJDjJNyXuii4_CirQgeER44djooT_bVnFQ
GOOGLE_SHEETS_GID=1436645756
GOOGLE_SHEETS_RANGE=A1:I36
GOOGLE_SHEETS_PUBLIC_CSV_URL=
GOOGLE_SHEETS_API_KEY=
BRACKET_MAX_ROWS=36
BRACKET_MAX_COLUMNS=9
BRACKET_FETCH_TIMEOUT_MS=3000
BRACKET_CACHE_TTL_MS=60000
