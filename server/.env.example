# Copy this file to server/.env

PORT=3001
HOST=127.0.0.1
CLIENT_URL=https://manalan.ru,https://www.manalan.ru

# Admin credentials are required in production.
# Generate a salt and hash, then set a non-default login:
# node -e "const { randomBytes, pbkdf2Sync } = require('crypto'); const password = process.argv[1]; const salt = randomBytes(16).toString('hex'); const hash = pbkdf2Sync(password, salt, 120000, 32, 'sha256').toString('hex'); console.log(`ADMIN_PASSWORD_SALT=${salt}\nADMIN_PASSWORD_HASH=${hash}`);" "CHANGE_ME"
ADMIN_LOGIN=
ADMIN_PASSWORD_SALT=
ADMIN_PASSWORD_HASH=
ADMIN_LOGIN_MAX_ATTEMPTS=5
ADMIN_LOGIN_WINDOW_MS=60000

